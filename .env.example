# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=sqlite:///jarvis.db
REDIS_URL=redis://localhost:6379/0

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret_key
API_CORS_ORIGINS=http://localhost:8000
WS_HEARTBEAT=30
WS_MAX_CONNECTIONS=100

# LLM Configuration
DEFAULT_LLM=openai  # openai, claude, gemini, or ollama
OPENAI_MODEL=gpt-4-turbo-preview
CLAUDE_MODEL=claude-3-opus-20240229
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Voice
VOICE_ENABLED=false
TTS_ENGINE=pyttsx3  # pyttsx3, elevenlabs, azure
STT_ENGINE=whisper  # whisper, google, azure
VOICE_PROFILE=local  # local, cloud
VOICE_STT_PROVIDER=whisper
VOICE_TTS_PROVIDER=pyttsx3
VOICE_CLOUD_STT_PROVIDER=whisper
VOICE_CLOUD_TTS_PROVIDER=gtts
VOICE_FALLBACK_TO_LOCAL=true
VOICE_LANGUAGE=en
WHISPER_MODEL=base
USE_WHISPER_API=false
GOOGLE_STT_USE_CLOUD=false
GOOGLE_APPLICATION_CREDENTIALS=
TTS_RATE=200
TTS_VOLUME=0.9
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ENABLE_WAKE_WORD=false
WAKE_WORD_PHRASE=Jarvis Babu
WAKE_WORD_KEYWORD_PATH=
WAKE_WORD_SENSITIVITY=0.5
PORCUPINE_ACCESS_KEY=

# Features
ENABLE_MEMORY=true
ENABLE_WEB_SEARCH=true
ENABLE_VOICE=false
ENABLE_PLUGINS=true

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/jarvis.log

# Security
JWT_SECRET_KEY=change_this_to_a_random_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400  # 24 hours in seconds

# User Data
USER_DATA_DIR=./user_data
CONVERSATION_HISTORY_DIR=./user_data/conversations
MEMORY_STORE_DIR=./user_data/memory

# Development
DEBUG=false
TESTING=false
