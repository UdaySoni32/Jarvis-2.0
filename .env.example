# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jarvis2
REDIS_URL=redis://localhost:6379/0

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret_key
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM Configuration
DEFAULT_LLM=openai  # openai, anthropic, or ollama
OPENAI_MODEL=gpt-4-turbo-preview
CLAUDE_MODEL=claude-3-opus-20240229
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Voice
VOICE_ENABLED=false
TTS_ENGINE=pyttsx3  # pyttsx3, elevenlabs, azure
STT_ENGINE=whisper  # whisper, google, azure

# Features
ENABLE_MEMORY=true
ENABLE_WEB_SEARCH=true
ENABLE_VOICE=false
ENABLE_PLUGINS=true

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/jarvis.log

# Security
JWT_SECRET_KEY=change_this_to_a_random_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400  # 24 hours in seconds

# User Data
USER_DATA_DIR=./user_data
CONVERSATION_HISTORY_DIR=./user_data/conversations
MEMORY_STORE_DIR=./user_data/memory

# Development
DEBUG=false
TESTING=false
